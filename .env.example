# Copy this file to .env on the server and fill in your own values.
# Do not commit or share your real .env.

LLM_PROVIDER=openai
OPENAI_API_KEY=YOUR_API_KEY_HERE
# Official OpenAI endpoint. Replace this with your OpenAI-compatible proxy URL
# if you are not using api.openai.com directly.
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: use a separate endpoint/key for embeddings.
# If omitted, OPENAI_API_KEY / OPENAI_BASE_URL are used.
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=

# Defaults used by the paper/README path.
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Graph is not needed for B / B+TF.
SA_MEM_ENABLE_GRAPH=0
